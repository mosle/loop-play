{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "loop-play",
  "version": "0.1.1",
  "identifier": "com.mosless.loop-play",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loop Play - Controller",
        "width": 480,
        "height": 700,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCQTI4MkFEQzg1NzJGNEYKUldSUEwxZklyWUtpKzBkTitvY2F1OVhOWE1wOUR4ajU4U0owYmNLKzk2ZStMeDh5ayt1akZBbUsK",
      "endpoints": [
        "https://github.com/mosle/loop-play/releases/latest/download/latest.json"
      ]
    }
  }
}
